# ===========================================
# Arsenal Ops - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED: Azure OpenAI Configuration
# ===========================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ===========================================
# REQUIRED: Database Configuration
# ===========================================
# For Render PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:port/database
# For Supabase:
# DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
# For Neon:
# DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://productmind:productmind_secret@postgres:5432/productmind

# ===========================================
# REQUIRED: JWT signing secret
# ===========================================
# Symmetric HS256 key used to sign and verify auth tokens. Also guards the
# authenticated /mcp surface (fastmcp's JWTVerifier validates Bearer tokens
# against it). The app REFUSES TO START if this is unset or left at the legacy
# default "your-secret-key-change-in-production". Generate a strong random value
# (e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`).
# WARNING: changing SECRET_KEY invalidates all live sessions (forces re-login).
SECRET_KEY=change-me-to-a-long-random-string

# ===========================================
# REQUIRED: Frontend URL (for CORS)
# ===========================================
# Set to your Vercel/Netlify URL in production
CORS_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com

# ===========================================
# Environment
# ===========================================
# Set to "production" in production
ENVIRONMENT=development

# ===========================================
# OPTIONAL: GitHub Integration
# ===========================================
# GitHub Personal Access Token with repo scope
# Used for sending repository invitations
GITHUB_TOKEN=

# ===========================================
# OPTIONAL: Email Notifications (SMTP)
# ===========================================
# For @mention and blocker notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com

# ===========================================
# OPTIONAL: Feature Flags
# ===========================================
# Enable/disable features
ENABLE_AI_FEATURES=true
ENABLE_GITHUB_INTEGRATION=false
ENABLE_EMAIL_NOTIFICATIONS=false

# ===========================================
# OPTIONAL: MCP server — Claude Desktop OAuth
# ===========================================
# The /mcp endpoint always accepts the app's Bearer JWT (Claude Code, the API
# connector, custom agents). To ALSO support Claude Desktop — which connects via
# OAuth 2.1 — set MCP_OAUTH_ENABLED=1. OAuth reuses the app's Google SSO client
# (GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET); you must register the MCP redirect
# URI in that Google OAuth client: <MCP_BASE_URL>/auth/callback
# (e.g. http://localhost:8000/mcp/auth/callback locally).
# MCP_BASE_URL is the public URL of the mounted /mcp (include the /mcp path).
MCP_OAUTH_ENABLED=0
MCP_BASE_URL=http://localhost:8000/mcp
# Allowlist of client redirect-URI patterns accepted during Dynamic Client
# Registration (comma-separated; wildcards allowed). Leave unset to use the safe
# default: loopback (Claude Desktop/mcp-remote) + Claude web origins. Setting this
# to a broad pattern re-opens DCR — keep it tight.
# MCP_ALLOWED_CLIENT_REDIRECT_URIS=http://localhost:*,http://127.0.0.1:*,https://claude.ai/*,https://claude.com/*

