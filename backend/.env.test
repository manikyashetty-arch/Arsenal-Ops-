# NOTE: DATABASE_URL is intentionally NOT set here. The test fixtures build
# their own in-memory SQLite engine (StaticPool) directly; the module-level
# engine in database.py is never used by tests. Setting DATABASE_URL to an
# in-memory URL here would make database.py build an in-memory engine with
# pool_size/max_overflow kwargs that SQLite's in-memory pool rejects.
SECRET_KEY=test-only-secret-do-not-use-in-prod
ADMIN_EMAILS=admin@test.local
DEV_AUTH_BYPASS=0
ENVIRONMENT=test
