{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    // Vendored shadcn/ui primitives. Treated as entry points (not `ignore`d) so
    // their intentionally-unused exports aren't reported, while the Radix /
    // form / use-mobile imports they pull in are still counted as used. Plain
    // `ignore` would drop them from the graph and produce ~20 false-positive
    // "unused dependency" reports.
    "src/components/ui/**",
    // Test scaffolding: the MSW mock backend and the render/auth toolkit
    // (docs/frontend-testing-guide.md). These deliberately expose a broader API
    // than any single test uses today (the full render ladder, auth overrides,
    // per-domain stores), so their "unused" exports are intentional, while the
    // generated-type and lib imports they pull in stay counted as used.
    "src/test-utils/**",
    "src/mocks/**"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignoreExportsUsedInFile": true,
  // `src/client/**` is generated by @hey-api/openapi-ts from the backend
  // OpenAPI schema and is never hand-edited (it's eslint-ignored too). It emits
  // a Data/Error/Responses type per endpoint, most of which the app doesn't
  // consume — reporting those as "unused exports" is pure noise, so the whole
  // generated tree is ignored.
  "ignore": ["src/client/**"],
  // `python` is invoked by the `gen:schema` npm script (it shells out to the
  // backend's export_openapi.py); it's a system binary, not an npm dependency.
  "ignoreBinaries": ["python"],
  "ignoreDependencies": []
}
